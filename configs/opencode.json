{
    "$schema": "https://opencode.ai/config.json",
    "default_agent": "plan",
    "theme": "gruvbox",
    "permission": {
        "edit": "ask"
    },
    "tui": {
        "copy_on_select": true
    },
    "provider": {
        "ollama": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "Ollama (local)",
            "options": {
                "baseURL": "{env:OLLAMA_HOST}/v1"
            },
            "models": {
                "qwen3.5": {},
                "qwen3.6": {},
                "qwen3-coder-next": {},
                "glm-4.7-flash": {},
                "hf.co/bartowski/Llama-3.2-1B-Instruct-GGUF":{},
                "hf.co/prism-ml/Bonsai-8B-gguf": {}
            }
        },
        "vllm": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "vLLM (local)",
            "options": {
                "baseURL": "{env:VLLM_HOST}/v1"
            },
            "models": {
                "local-vllm": {}
            }
        }
    }
}
